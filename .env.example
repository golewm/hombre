# Hombre Configuration
# Copy this to .env and fill in your values

# ─── Honcho Server ──────────────────────────────────────────
HONCHO_URL=http://host.docker.internal:8000
HONCHO_ENV_PATH=/path/to/honcho/.env
HONCHO_COMPOSE_DIR=/path/to/honcho
# HONCHO_API_KEY=

# ─── Dashboard Auth (Basic Auth - fallback when Supabase not configured) ──
# DASHBOARD_USER=admin
# DASHBOARD_PASSWORD=changeme
# DASHBOARD_ROLE=admin
# DASHBOARD_USERS=user1:pass1:admin,user2:pass2:viewer

# ─── Supabase (optional - enables Supabase auth + database storage) ──
# Get these from your Supabase projectSettings > API
SUPABASE_URL=http://localhost:54321
SUPABASE_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ─── Logging ────────────────────────────────────────────────
# HOMBRE_LOG_DIR=logs
